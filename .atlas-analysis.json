  "keyFeatures": [
    "Simple API with ingest/search/ask functions",
    "Agentic RAG pipeline with query expansion and self-correction",
    "GraphRAG with entity extraction and community detection",
    "Hybrid search combining vector and full-text",
    "Pluggable embeddings (Bumblebee, OpenAI, custom)",
    "Multiple vector store backends (pgvector, HNSWLib)",
    "LiveView dashboard for document management",
    "Built-in evaluation metrics (MRR, Recall, Precision)",
    "Comprehensive telemetry and observability"
  ],
